{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "qmldir",
      "camelcase": "Qmldir",
      "title": "Qmldir",
      "scope": "source.qmldir",
      "file-types": [
        "qmldir"
      ],
      "injection-regex": "^qmldir$",
      "class-name": "TreeSitterQmldir"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "tree-sitter for qmldir",
    "authors": [
      {
        "name": "Decodetalkers",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter-grammars/tree-sitter-qmldir",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
